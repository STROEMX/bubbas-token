# Private key of the deployer wallet (WITHOUT 0x prefix)
# NEVER commit the real .env file to version control
PRIVATE_KEY=your_wallet_private_key_here

# BSC Mainnet RPC (default: https://bsc-dataseed1.binance.org)
BSC_RPC_URL=https://bsc-dataseed1.binance.org

# BSC Testnet RPC (default: https://data-seed-prebsc-1-s1.binance.org:8545)
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# Ops wallet address (hot wallet for backend fee payments)
# If not set, defaults to deployer address
OPS_WALLET=

# BSCScan API key (for contract verification)
# Get one at https://bscscan.com/myapikey
BSCSCAN_API_KEY=
